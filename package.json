{
  "name": "back-express",
  "version": "1.0.0",
  "description": "Back-end Express archetype",
  "type": "module",
  "scripts": {
    "dev": "nub watch server.ts",
    "start": "nub server.ts",
    "test": "nub --test **/*.test.ts",
    "test:watch": "nub --test --watch **/*.test.ts",
    "format": "oxfmt ",
    "lint": "oxlint --fix --fix-suggestions --fix-dangerously  --format=agent ",
    "typecheck": "oxlint --type-aware --type-check --format=agent ."
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "^7.0.1-rc"
  },
  "engines": {
    "node": ">=26.0.0"
  }
}
